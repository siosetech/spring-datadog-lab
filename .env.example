# Copy to `.env` in the repo root (Compose auto-loads it). Do not commit `.env`.

# Datadog (required for otel-collector + agent export to us5)
DD_API_KEY=
DD_SITE=us5.datadoghq.com

# Postgres (Compose defaults match application-dev.yml)
POSTGRES_USER=lab
POSTGRES_PASSWORD=lab
POSTGRES_DB=datadog_lab_db

# Optional Vault (Compose Vault uses this)
VAULT_DEV_ROOT_TOKEN_ID=root
